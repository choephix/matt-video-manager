# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/ai-app-template"

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# File Paths
DROPBOX_PATH="/path/to/dropbox/courses"
FINISHED_VIDEOS_DIRECTORY="/path/to/finished-videos"
DUMP_FILE_LOCATION="/path/to/database-backups/cvm.json"
OBS_RECORDING_DIR="/path/to/obs-recordings"
# How OBS recording paths should be interpreted by the backend.
# Use "wsl" when running the app/ffmpeg in WSL. Use "native" when running
# native Windows Node/ffmpeg against Windows paths from OBS.
OBS_RECORDING_PATH_MODE="wsl"

# Video encoder used when exporting final MP4s.
# Default/original: "h264_nvenc" for NVIDIA hardware encoding.
# If export fails with "Driver does not support the required nvenc API version",
# update NVIDIA drivers, then switch this back to "h264_nvenc". Use "libx264"
# as a slower CPU fallback while the driver is outdated.
FFMPEG_VIDEO_ENCODER="h264_nvenc"

# Standalone Video Files
# Directory where files associated with standalone videos are stored.
# Files are organized as: {STANDALONE_VIDEO_FILES_DIR}/{videoId}/{filename}
STANDALONE_VIDEO_FILES_DIR="/path/to/standalone-video-files"

# Google OAuth (for YouTube uploads)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# Background Removal (remove.bg)
# Get an API key at https://www.remove.bg/api (50 free images/month)
REMOVE_BG_API_KEY="your_remove_bg_api_key_here"
